{
  "name": "@arm/scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p ../../packages/contracts/tsconfig.json && tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:android": "npm run build && npx cap sync android",
    "cap:ios": "npm run build && npx cap sync ios",
    "android:apk": "npm run cap:android && cd android && gradlew.bat assembleDebug",
    "android:open": "npx cap open android",
    "android:live": "node ../../scripts/scanner-android-live.mjs",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@arm/contracts": "0.1.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@supabase/supabase-js": "^2.49.4",
    "idb": "^8.0.2",
    "qr-scanner": "^1.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
